@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- SEARCH -->
                <form id="formSearch"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="productSearchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <input type="hidden" asp-for="PageSize" />
                    <input type="hidden" asp-for="CategoryID" />
                    <input type="hidden" asp-for="SupplierID" />
                    <input type="hidden" asp-for="MinPrice" />
                    <input type="hidden" asp-for="MaxPrice" />

                    <div class="input-group">
                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" />

                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- KẾT QUẢ -->
                <div id="productSearchResult" class="mt-3"></div>
            </div>
        </div>
    </div>

    <!-- GIỎ HÀNG + KHÁCH -->
    <div class="col-8">

        <!-- GIỎ HÀNG -->
        <div class="row">
            <div class="col-12" id="cart"></div>
        </div>

        <!-- THÔNG TIN -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" onsubmit="createOrder(event, this)">

                            <!-- KHÁCH HÀNG -->
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select"
                                            name="customerID"
                                            asp-items=" await SelectListHelper.CustomersAsync()">
                                    </select>
                                </div>
                            </div>

                            <!-- TỈNH -->
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select"
                                            name="Province"
                                            asp-items="await SelectListHelper.ProvincesAsync()">
                                    </select>
                                </div>
                            </div>

                            <!-- ĐỊA CHỈ -->
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control"
                                              name="Address"></textarea>
                                </div>
                            </div>

                            <!-- SUBMIT -->
                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });

        // ================= GIỎ HÀNG =================

        function showCart() {
            fetch('/Order/ShowCart')
            .then(res => res.text())
            .then(html => {
                document.getElementById('cart').innerHTML = html;
            });
        }

        function addCartItem(event, form) {
            event.preventDefault();
            const data = new FormData(form);

            fetch('/Order/AddCartItem', {
                method: 'POST',
                body: data
            })
            .then(res => res.json())
            .then(rs => {
                if (rs.code === 0) alert(rs.message);
                else showCart();
            });
        }

        function deleteCartItem(productID) {
            fetch('/Order/DeleteCartItem?productID=' + productID, {
                method: 'POST'
            })
            .then(res => {
                // TÌM CÁI POPUP VÀ BẮT NÓ ĐÓNG LẠI
                const modalElement = document.getElementById("dialogModal");
                if (modalElement) {
                    const m = bootstrap.Modal.getInstance(modalElement) || new bootstrap.Modal(modalElement);
                    m.hide();
                }

                // CẬP NHẬT LẠI CÁI BẢNG GIỎ HÀNG
                showCart();
            });
        }

        function clearCart() {
            fetch('/Order/ClearCart', {
                method: 'POST'
            })
            .then(() => showCart());
        }

        function updateCartItem(event, form) {
            event.preventDefault();
            const data = new FormData(form);

            fetch('/Order/UpdateCartItem', {
                method: 'POST',
                body: data
            })
            .then(res => res.json())
            .then(rs => {
                if (rs.code === 0) {
                    alert(rs.message);
                } else {
                    const modal = document.getElementById("dialogModal");
                    if (modal) {
                        const m = bootstrap.Modal.getInstance(modal)
                            || new bootstrap.Modal(modal);
                        m.hide();
                    }
                    showCart();
                }
            });
        }

        // ================= TẠO ĐƠN =================

        function createOrder(event, form) {
            event.preventDefault();
            const data = new FormData(form);

            fetch('/Order/CreateOrder', {
                method: 'POST',
                body: data
            })
            .then(res => res.json())
            .then(rs => {
                if (rs.code === 0) {
                    alert(rs.message);
                } else {
                    window.location.href = '/Order/Detail/' + rs.code;
                }
            });
        }

    </script>
}