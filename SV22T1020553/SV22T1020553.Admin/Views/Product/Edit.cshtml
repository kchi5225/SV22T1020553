@model Product
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i> Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SaveData" enctype="multipart/form-data">
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" asp-for="ProductName" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select class="form-select" asp-for="CategoryID" asp-items="await SelectListHelper.Categories()"></select>
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="SupplierID" asp-items="await SelectListHelper.Suppliers()"></select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text" class="form-control" asp-for="Unit" />
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="hidden" id="PriceHidden" name="Price" value="@Model.Price.ToString("0")" />
                            <input type="text" id="PriceDisplay" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsSelling" />
                                <label class="form-check-label" for="IsSelling">Đang bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="hidden" asp-for="Photo" />
                            <input type="file" class="form-control" name="uploadPhoto" accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2">
                                <img id="imgPreview" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail" style="max-height: 160px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" rows="3" asp-for="ProductDescription"></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@using SV22T1020553.BusinessLayers
@{
    if (Model.ProductID > 0)
    {
        var attributes = await CatalogDataService.ListAttributesAsync(Model.ProductID);
        var photos = await CatalogDataService.ListPhotosAsync(Model.ProductID);

        await Html.RenderPartialAsync("ListAttributes", attributes);
        await Html.RenderPartialAsync("ListPhotos", photos);
    }
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Hàm định dạng số có tính năng dọn dẹp số 0 ở đầu
            function formatNumber(num) {
                if (!num) return "";
                let cleanStr = String(num).replace(/\D/g, "");
                if (cleanStr === "") return "";

                // Ép sang số nguyên (parseInt) để triệt tiêu các số 0 vô nghĩa ở đầu
                let parsedNum = parseInt(cleanStr, 10);
                return String(parsedNum).replace(/\B(?=(\d{3})+(?!\d))/g, ".");
            }

            function setupSingleMoneyField(displayId, hiddenId) {
                let displayObj = document.getElementById(displayId);
                let hiddenObj = document.getElementById(hiddenId);

                if (!displayObj || !hiddenObj) return;

                // 1. Khi load trang: Gắn số từ C# đẩy xuống lên thẻ hiển thị
                if (hiddenObj.value && hiddenObj.value > 0) {
                    displayObj.value = formatNumber(hiddenObj.value);
                }

                // 2. Click vào ô (Focus): Bỏ dấu chấm để gõ, chống nhảy con trỏ chuột
                displayObj.addEventListener("focus", function () {
                    this.value = hiddenObj.value;
                });

                // 3. Đang gõ (Input): Ép gõ số nguyên, dọn sạch chữ và số 0 ở đầu
                displayObj.addEventListener("input", function () {
                    let rawValue = this.value.replace(/\D/g, "");

                    if(rawValue !== "") {
                        rawValue = parseInt(rawValue, 10).toString();
                    }

                    this.value = rawValue;       // Hiện trực tiếp cho người dùng
                    hiddenObj.value = rawValue;  // Gắn số chuẩn vào thẻ ẩn để gửi về Server
                });

                // 4. Click ra ngoài (Blur): Format lại dấu chấm cho đẹp
                displayObj.addEventListener("blur", function () {
                    if (this.value) {
                        this.value = formatNumber(this.value);
                    }
                });
            }

            // Kích hoạt hàm
            setupSingleMoneyField("PriceDisplay", "PriceHidden");
        });
    </script>
}