@model SV22T1020553.Shop.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<div class="container my-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-box-seam me-2"></i>Xác nhận đơn hàng</h2>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin giao hàng</h5>

                    <form asp-controller="Cart" asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tên người nhận <span class="text-danger">*</span></label>
                            <input asp-for="DeliveryName" class="form-control shadow-sm" maxlength="30" placeholder="Nhập tên người nhận hàng..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="DeliveryPhone" type="tel" class="form-control shadow-sm" maxlength="15" placeholder="Nhập số điện thoại liên hệ..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                            <select asp-for="DeliveryProvince" class="form-select shadow-sm" required>
                                <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                @if (Model.Provinces != null)
                                {
                                    foreach (var p in Model.Provinces)
                                    {
                                        <option value="@p.ProvinceName">@p.ProvinceName</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="DeliveryProvince" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Địa chỉ chi tiết (Số nhà, đường, xã...) <span class="text-danger">*</span></label>
                            <textarea asp-for="DeliveryAddress" class="form-control shadow-sm" rows="2" maxlength="100" placeholder="Ví dụ: 123 Lê Lợi, Phường Bến Thành..."></textarea>
                            <span asp-validation-for="DeliveryAddress" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Ghi chú thêm (Tùy chọn)</label>
                            <textarea asp-for="Notes" class="form-control shadow-sm" rows="2" maxlength="100" placeholder="Ví dụ: Giao hàng giờ hành chính, gọi trước khi giao..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại giỏ hàng
                            </a>
                            <button type="submit" class="btn btn-warning text-dark fw-bold px-4 py-2 shadow-sm">
                                XÁC NHẬN ĐẶT HÀNG <i class="bi bi-check2-circle ms-1"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Đơn hàng của bạn</h5>

                    <div class="order-items-scroll mb-3" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3 pe-2">
                                <div class="d-flex align-items-center">
                                    <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="rounded border me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                    <div>
                                        <h6 class="mb-0 fw-bold" style="font-size: 0.95rem;">@item.ProductName</h6>
                                        <small class="text-muted">SL: @item.Quantity x @item.SalePrice.ToString("N0") đ</small>
                                    </div>
                                </div>
                                <span class="fw-bold text-danger">@((item.SalePrice * item.Quantity).ToString("N0")) đ</span>
                            </div>
                        }
                    </div>

                    <div class="border-top pt-3 mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính:</span>
                            <span class="fw-bold">@Model.CartItems.Sum(x => x.SalePrice * x.Quantity).ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí giao hàng:</span>
                            <span class="fw-bold text-success">Miễn phí</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <span class="fw-bold fs-5">TỔNG TIỀN:</span>
                            <span class="fw-bold fs-4 text-danger">@Model.CartItems.Sum(x => x.SalePrice * x.Quantity).ToString("N0") đ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>