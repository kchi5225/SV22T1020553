@model SV22T1020553.Shop.Models.CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container my-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Giỏ hàng của bạn</h2>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="alert alert-info text-center shadow-sm p-5">
            <i class="bi bi-cart-x display-1 text-secondary mb-3"></i>
            <h4>Giỏ hàng của bạn đang trống</h4>
            <p>Hãy quay lại trang chủ để chọn cho mình những sản phẩm tuyệt vời nhé!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-warning text-dark fw-bold mt-2 shadow-sm">
                <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center">Đơn giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-center">Thành tiền</th>
                                    <th class="text-center pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                                     class="rounded me-3 border" style="width: 50px; height: 50px; object-fit: cover;">
                                                <span class="fw-bold">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-center text-danger fw-semibold">
                                            @item.SalePrice.ToString("N0") đ
                                        </td>

                                        <td class="text-center">
                                            <form asp-controller="Cart" asp-action="Update" method="post" class="d-flex justify-content-center">
                                                <input type="hidden" name="productId" value="@item.ProductID" />
                                                <div class="input-group input-group-sm shadow-sm" style="width: 120px;">
                                                    <input type="number" name="quantity" class="form-control text-center fw-bold" value="@item.Quantity" min="1" />
                                                    <button type="submit" class="btn btn-outline-primary" title="Lưu số lượng">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </div>
                                            </form>
                                        </td>

                                        <td class="text-center text-danger fw-bold">
                                            @((item.SalePrice * item.Quantity).ToString("N0")) đ
                                        </td>

                                        <td class="text-center pe-4">
                                            <form id="remove-form-@item.ProductID" asp-controller="Cart" asp-action="Remove" method="post" class="d-none">
                                                <input type="hidden" name="productId" value="@item.ProductID" />
                                            </form>

                                            <button type="button" class="btn btn-sm btn-danger shadow-sm"
                                                    onclick="confirmRemove(@item.ProductID, '@item.ProductName')" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="card-footer bg-white border-top-0 text-end py-3 pe-4">
                        <form id="clear-cart-form" asp-controller="Cart" asp-action="Clear" method="post" class="d-none"></form>
                        <button type="button" class="btn btn-outline-danger" onclick="confirmClearCart()">
                            <i class="bi bi-trash3-fill me-1"></i> Xóa toàn bộ giỏ hàng
                        </button>
                    </div>

                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Tóm tắt đơn hàng</h5>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng số sản phẩm:</span>
                            <span class="fw-bold">@Model.Items.Sum(x => x.Quantity)</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4 align-items-center">
                            <span class="text-muted">Tổng tiền:</span>
                            <span class="fs-4 text-danger fw-bold">
                                @Model.Items.Sum(x => x.SalePrice * x.Quantity).ToString("N0") đ
                            </span>
                        </div>

                        <a asp-controller="Cart" asp-action="Checkout" class="btn btn-warning text-dark w-100 py-2 fw-bold mb-3 shadow-sm">
                            TIẾN HÀNH THANH TOÁN <i class="bi bi-chevron-right ms-1"></i>
                        </a>

                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 py-2">
                            <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
    
    function confirmRemove(id, name) {
        Swal.fire({
            title: 'Xóa sản phẩm?',
            text: `Bạn có chắc muốn xóa "${name}" khỏi giỏ hàng?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Xóa ngay',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('remove-form-' + id).submit();
            }
        });
    }

    function confirmClearCart() {
        Swal.fire({
            title: 'Xóa toàn bộ giỏ hàng?',
            text: 'Tất cả sản phẩm sẽ bị xóa khỏi giỏ hàng. Bạn không thể hoàn tác hành động này!',
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Chắc chắn xóa',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('clear-cart-form').submit();
            }
        });
    }
</script>