@using SV22T1020553.Models.Sales
@using SV22T1020553.Models.Common
@model IEnumerable<OrderDetailViewInfo>
@{
    var order = ViewBag.Order as OrderViewInfo;
    ViewBag.Title = "Theo dõi đơn hàng #" + order?.OrderID;

    int status = order != null ? (int)order.Status : 0;
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-4"><i class="bi bi-box-seam me-2"></i>Trạng thái đơn hàng #@order?.OrderID</h2>
        <a asp-action="OrderHistory" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Quay lại lịch sử
        </a>
    </div>

    @if (order != null)
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body py-5">
                <div class="row text-center position-relative">
                    @* Đường nối giữa các bước *@
                    <div class="position-absolute top-50 start-0 translate-middle-y w-100 px-5 d-none d-md-block" style="height: 2px; background-color: #e9ecef; z-index: 0;">
                        <div style="height: 100%; background-color: #0d6efd; width: @(status == 4 ? "100%" : (status == 3 ? "66%" : (status == 2 ? "33%" : "0%"))); transition: 0.5s;"></div>
                    </div>

                    <div class="col position-relative" style="z-index: 1;">
                        <div class="rounded-circle bg-@(status >= 1 ? "primary" : "secondary") text-white d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 50px; height: 50px;">
                            <i class="bi bi-cart-plus fs-4"></i>
                        </div>
                        <p class="fw-bold mb-0">Đã đặt</p>
                        <small class="text-muted">@order.OrderTime.ToString("dd/MM")</small>
                    </div>

                    <div class="col position-relative" style="z-index: 1;">
                        <div class="rounded-circle bg-@(status >= 2 ? "primary" : "secondary") text-white d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 50px; height: 50px;">
                            <i class="bi bi-clipboard-check fs-4"></i>
                        </div>
                        <p class="fw-bold mb-0">Đã duyệt</p>
                        <small class="text-muted">@(order.AcceptTime?.ToString("dd/MM") ?? "--")</small>
                    </div>

                    <div class="col position-relative" style="z-index: 1;">
                        <div class="rounded-circle bg-@(status >= 3 ? "primary" : "secondary") text-white d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 50px; height: 50px;">
                            <i class="bi bi-truck fs-4"></i>
                        </div>
                        <p class="fw-bold mb-0">Đang giao</p>
                        <small class="text-muted">@(order.ShippedTime?.ToString("dd/MM") ?? "--")</small>
                    </div>

                    <div class="col position-relative" style="z-index: 1;">
                        <div class="rounded-circle bg-@(status == 4 ? "success" : "secondary") text-white d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 50px; height: 50px;">
                            <i class="bi bi-check-lg fs-4"></i>
                        </div>
                        <p class="fw-bold mb-0">Hoàn thành</p>
                        <small class="text-muted">@(order.FinishedTime?.ToString("dd/MM") ?? "--")</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2"></i>Kiện hàng</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end pe-4">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                                         class="rounded border me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                                                    <div>
                                                        <div class="fw-bold">@item.ProductName</div>
                                                        <small class="text-muted">@item.Unit</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end pe-4 fw-bold">@((item.Quantity * item.SalePrice).ToString("N0")) đ</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="bg-light">
                                    <tr>
                                        <td colspan="2" class="text-end fw-bold py-3">Tổng giá trị đơn hàng:</td>
                                        <td class="text-end pe-4 fw-bold text-danger fs-5 py-3">@Model.Sum(x => x.Quantity * x.SalePrice).ToString("N0") đ</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-geo-alt me-2"></i>Địa chỉ nhận hàng</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-1 text-muted">@order.DeliveryAddress</p>
                        <p class="mb-0 fw-bold">Tỉnh/thành: @order.DeliveryProvince</p>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-truck me-2"></i>Đơn vị vận chuyển</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(order.ShipperName))
                        {
                            <p class="mb-1 fw-bold text-primary">@order.ShipperName</p>
                            <p class="mb-0 small text-muted"><i class="bi bi-telephone me-1"></i> @order.ShipperPhone</p>
                        }
                        else
                        {
                            <p class="text-muted mb-0 italic">Đang chờ cập nhật người giao hàng...</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* Style bổ sung cho biểu tượng *@
<style>
    .bi {
        vertical-align: middle;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
    }
</style>