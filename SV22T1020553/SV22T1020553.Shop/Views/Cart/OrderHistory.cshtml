@using SV22T1020553.Models.Sales
@using SV22T1020553.Models.Common
@model IEnumerable<OrderViewInfo>

@{
    ViewBag.Title = "Lịch sử mua hàng";
}

<div class="container my-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng</h2>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">#@item.OrderID</td>
                        <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                          
                            @switch ((OrderStatusEnum)item.Status)
                            {
                                case OrderStatusEnum.New:
                                    <span class="badge bg-info text-dark">Đơn hàng mới</span>
                                    break;
                                case OrderStatusEnum.Accepted:
                                    <span class="badge bg-primary">Đã duyệt</span>
                                    break;
                                case OrderStatusEnum.Shipping:
                                    <span class="badge bg-warning text-dark">Đang giao</span>
                                    break;
                                case OrderStatusEnum.Completed:
                                    <span class="badge bg-success">Thành công</span>
                                    break;
                                case OrderStatusEnum.Cancelled:
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                                case OrderStatusEnum.Rejected:
                                    <span class="badge bg-secondary">Bị từ chối</span>
                                    break;
                                default:
                                    <span class="badge bg-dark">Khác</span>
                                    break;
                            }
                        </td>
                        <td class="text-danger fw-bold text-end">
                            @item.TotalPrice.ToString("N0") đ
                        </td>
                        <td class="text-center">

                            <a asp-controller="Cart" asp-action="OrderDetails" asp-route-id="@item.OrderID"
                               class="btn btn-sm btn-outline-warning text-dark fw-bold w-100 mb-1">
                                <i class="bi bi-search"></i> Theo dõi đơn
                            </a>

                            
                            @if ((int)item.Status == 1)
                            {
                                <a asp-controller="Cart" asp-action="CancelOrder" asp-route-id="@item.OrderID"
                                   class="btn btn-sm btn-outline-danger w-100"
                                   onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng #@item.OrderID này không?');">
                                    <i class="bi bi-x-circle"></i> Hủy đơn
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>