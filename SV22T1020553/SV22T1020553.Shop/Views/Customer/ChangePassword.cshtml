@model ChangePasswordViewModel

<h2>Đổi mật khẩu</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<form method="post">
    <div class="mb-3">
        <label>Mật khẩu cũ</label>
        <input type="password" class="form-control" asp-for="OldPassword" />
        <span class="text-danger" asp-validation-for="OldPassword"></span>
    </div>

    <div class="mb-3">
        <label>Mật khẩu mới</label>
        <input type="password" class="form-control" asp-for="NewPassword" />
        <span class="text-danger" asp-validation-for="NewPassword"></span>
    </div>

    <div class="mb-3">
        <label>Xác nhận mật khẩu</label>
        <input type="password" class="form-control" asp-for="ConfirmPassword" />
        <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
    </div>

    <button class="btn btn-primary">Đổi mật khẩu</button>
</form>