@model SV22T1020553.Shop.Models.ProductDetailViewModel

<h2 class="fw-bold mb-3">@Model.Product.ProductName</h2>

<h3 class="text-danger fw-bold mb-3">
    @Model.Product.Price.ToString("N0") VNĐ <span class="fs-5 text-muted">/ @Model.Product.Unit</span>
</h3>

<div class="mb-4">
    <p class="mb-2">
        <strong>Loại hàng:</strong> @Model.Product.CategoryName
    </p>
    <p class="mb-2">
        <strong>Nhà cung cấp:</strong> @Model.Product.SupplierName
    </p>

    <p class="mb-2">
        <strong>Trạng thái:</strong>
        @if (Model.Product.IsSelling)
        {
            <span class="badge bg-success">Đang Bán</span>
        }
        else
        {
            <span class="badge bg-danger">Ngừng hết hàng</span>
        }
    </p>

    <p class="mt-3 mb-1"><strong>Mô tả chi tiết:</strong></p>
    <div class="p-3 bg-light rounded border text-break">
        @Model.Product.ProductDescription
    </div>
</div>

@if (Model.Attributes != null && Model.Attributes.Any())
{
    <h5 class="fw-bold mt-4 border-bottom pb-2">Thông số kỹ thuật</h5>
    <table class="table table-bordered table-striped mt-3 shadow-sm">
        <tbody>
            @foreach (var attr in Model.Attributes)
            {
                <tr>
                    <th style="width: 35%;" class="bg-light">@attr.AttributeName</th>
                    <td>@attr.AttributeValue</td>
                </tr>
            }
        </tbody>
    </table>
}

<hr class="my-4" />

<form asp-controller="Cart" asp-action="Add" method="post" class="d-flex align-items-center gap-3">
    <input type="hidden" name="productId" value="@Model.Product.ProductID" />

    <div class="input-group" style="width: 140px;">
        <span class="input-group-text bg-light">SL</span>
        <input type="number" name="quantity" class="form-control text-center fw-bold" value="1" min="1" />
    </div>

    <button type="submit" name="actionType" value="AddToCart" class="btn btn-warning px-4 py-2 fw-bold text-dark shadow-sm">
        <i class="bi bi-cart-plus me-1"></i> Thêm vào giỏ hàng
    </button>

    <button type="submit" name="actionType" value="BuyNow" class="btn btn-danger px-4 py-2 fw-bold shadow-sm">
        <i class="bi bi-bag-check me-1"></i> Mua ngay
    </button>
</form>